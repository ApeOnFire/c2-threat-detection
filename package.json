{
  "name": "vantage-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "pnpm --parallel --filter \"./apps/*\" run start",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "vitest": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
