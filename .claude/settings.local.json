{
  "permissions": {
    "allow": ["Bash(*)", "Read(*)", "Glob(*)", "WebSearch", "WebFetch", "SlashCommand(/plan)"],
    "deny": [],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(npm publish*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo rm*)",
      "Bash(sudo*)"
    ]
  }
}
